# =============================================================================
# BOTFACTORY LEAD MACHINE — .env konfiguratsiya namunasi
# Ushbu faylni nusxalab, .env deb saqlang va qiymatlarni to'ldiring.
# =============================================================================


# =============================================================================
# 1. EMAIL TRANSPORT — qaysi usulda email yuboriladi
# =============================================================================
# Qiymatlar: "smtp" | "gmail-api" | "brevo"
EMAIL_TRANSPORT=smtp


# --- Gmail SMTP (EMAIL_TRANSPORT=smtp holatida) ---
GMAIL_EMAIL=sizningemail@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here
# App Password olish: Google → Xavfsizlik → 2FA → App Passwords

EMAIL_FROM_NAME=Botfactory AI
EMAIL_SENDER_EMAIL=sizningemail@gmail.com
EMAIL_REPLY_TO=sizningemail@gmail.com

# Imzo ma'lumotlari
EMAIL_SIGNATURE_NAME=Sizning Ismingiz
EMAIL_SIGNATURE_ROLE=Founder & CEO
EMAIL_SIGNATURE_COMPANY=Botfactory AI
EMAIL_SIGNATURE_PHONE=+998 90 000 00 00
EMAIL_SIGNATURE_WEBSITE=https://botfactory.uz


# --- Gmail API OAuth (EMAIL_TRANSPORT=gmail-api bo'lsa) ---
# GMAIL_API_CLIENT_ID=your-oauth-client-id
# GMAIL_API_CLIENT_SECRET=your-oauth-client-secret
# GMAIL_API_REFRESH_TOKEN=your-oauth-refresh-token
# GMAIL_API_TOKEN_URL=https://oauth2.googleapis.com/token
# GMAIL_API_SEND_URL=https://gmail.googleapis.com/gmail/v1/users/me/messages/send


# --- Brevo API (EMAIL_TRANSPORT=brevo bo'lsa) ---
# BREVO_API_KEY=your-brevo-api-key
# BREVO_API_URL=https://api.brevo.com/v3/smtp/email
# BREVO_SANDBOX_MODE=false


# =============================================================================
# 2. SCRAPER — GoldenPages.uz dan ma'lumot yig'ish
# =============================================================================
SCRAPE_SEED_URL=https://www.goldenpages.uz/search/?what=restoran&where=toshkent
SCRAPER_MAX_COMPANIES=200
SCRAPER_MAX_PAGES_PER_SEED=20

# Faqat ustuvor kategoriyalarni olish
FILTER_PRIORITY_CATEGORIES=false

# MX DNS tekshiruvi (sekin, lekin sifatli)
VALIDATE_EMAIL_MX=false


# =============================================================================
# 3. GEMINI AI — shaxsiy email matnlari yaratish (ixtiyoriy)
# =============================================================================
GEMINI_ENABLED=true
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash


# =============================================================================
# 4. BRAND — brend ma'lumotlari
# =============================================================================
BOTFACTORY_BRAND_NAME=Botfactory AI
EMAIL_REPLY_PHRASE=Xabarimga javob bering yoki 5 daqiqalik qo'ng'iroq belgilang
DISCOVERY_CALL_URL=https://cal.com/sizning-havolangiz


# =============================================================================
# 5. EMAIL YUBORISH TEZLIGI VA CHEKLOVLAR
# =============================================================================
EMAIL_MAX_PER_RUN=30
EMAIL_DELAY_MIN_SECONDS=15
EMAIL_DELAY_MAX_SECONDS=45
SMTP_RETRY_LIMIT=3


# =============================================================================
# 6. WARM-UP REJIMI — yangi pochta uchun sekin-asta oshirib borish
# =============================================================================
WARM_UP_MODE=false
WARM_UP_START_DAILY_LIMIT=5
WARM_UP_MAX_DAILY_LIMIT=80
WARM_UP_DAILY_INCREMENT=5


# =============================================================================
# 7. REPLY SYNC — javob berganlari avtomatik blacklistga qo'shish
# =============================================================================
REPLY_SYNC_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_FOLDER=INBOX
# UNSUBSCRIBE_KEYWORDS=stop,bekor,unsubscribe


# =============================================================================
# 8. FAYL YO'LLARI
# =============================================================================
LEADS_FILE=leads.xlsx
TEMPLATE_FILE=email_template.html
BLACKLIST_FILE=blacklist.json
LOGS_DIR=logs
SCRAPER_OUTPUT_DIR=scraper_output


# =============================================================================
# 9. GOOGLE SHEETS (ixtiyoriy — leads.xlsx o'rniga)
# =============================================================================
GOOGLE_SHEETS_ENABLED=false
# GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
# GOOGLE_SHEETS_WORKSHEET=Leads
# GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=your-base64-encoded-service-account-json


# =============================================================================
# 10. WEB SERVICE
# =============================================================================
PORT=5000
RENDER_TRIGGER_TOKEN=
RENDER_ENABLE_SCHEDULER=false
RENDER_SCHEDULE_CRON=0 6 * * *
RENDER_TIMEZONE=Asia/Tashkent


# =============================================================================
# 11. TIL
# =============================================================================
# "uz" = o'zbek tili, "ru" = rus tili
OUTREACH_LANGUAGE=uz
